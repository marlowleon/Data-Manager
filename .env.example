# Copy this file to .env and edit values before starting Data Manager.

DATA_MANAGER_ADMIN_USER=admin
DATA_MANAGER_ADMIN_PASSWORD=change-this-admin-password
DATA_MANAGER_VERSION=1.7.0

# Generate with: openssl rand -hex 32
DATA_MANAGER_SESSION_SECRET=replace-with-a-long-random-secret

# Optional. You can also paste this into Settings after the app starts.
TMDB_API_KEY=

# Keep this path stable. It stores the SQLite database with settings, users, logs, and job stats.
DATA_MANAGER_DATA_DIR=./data

# Use absolute host paths for your media folders.
DATA_MANAGER_WATCH_DIR=/path/to/downloads/completed
DATA_MANAGER_REVIEW_DIR=/path/to/downloads/to-review
DATA_MANAGER_QUARANTINE_DIR=/path/to/downloads/quarantine
DATA_MANAGER_MOVIE_DIR=/path/to/media/movies
DATA_MANAGER_TV_DIR=/path/to/media/tv-shows
